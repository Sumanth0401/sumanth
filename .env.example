# Copy to .env and fill in. .env is gitignored — never commit it.

# Google Gemini API key (used by the Express backend for the AI layer)
GEMINI_API_KEY=your_gemini_key_here

# Optional: Gemini model (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Firebase Web API key — used by the backend to verify Firebase ID tokens.
# This is the PUBLIC web key (safe to expose); included so token verification
# works without a service account. Defaults to the project's key if omitted.
FIREBASE_API_KEY=AIzaSyCx1HISQk4RQaR5UDN4oljdoFV7tNdwXyg

# Port for the Express backend (default 5050; avoid 5000 — macOS AirPlay uses it)
PORT=5050
